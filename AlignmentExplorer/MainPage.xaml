<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlignmentExplorer.MainPage"
             Title="Alignment Explorer">

    <Grid RowDefinitions="Auto, *, Auto, Auto"
          ColumnDefinitions="*, *"
          Padding="20"
          RowSpacing="20">

        <!-- Заголовок -->
        <Label Grid.Row="0" Grid.ColumnSpan="2"
               Text="Параметры выравнивания"
               FontSize="24"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <!-- Область для демонстрации выравнивания -->
        <Frame Grid.Row="1" Grid.ColumnSpan="2"
               BorderColor="Gray"
               CornerRadius="10"
               Padding="10"
               HeightRequest="300"
               BackgroundColor="LightGray">
            <Frame x:Name="DemoFrame"
                   BackgroundColor="CornflowerBlue"
                   CornerRadius="8"
                   Padding="10"
                   WidthRequest="120"
                   HeightRequest="80"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <Label Text="Метка"
                       TextColor="White"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Frame>
        </Frame>

        <!-- Панель горизонтального выравнивания -->
        <VerticalStackLayout Grid.Row="2" Grid.Column="0"
                              Spacing="10"
                              HorizontalOptions="Center">
            <Label Text="Горизонтальное выравнивание"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <HorizontalStackLayout Spacing="10">
                <Button Text="Start" Clicked="OnHorizontalStart" />
                <Button Text="Center" Clicked="OnHorizontalCenter" />
                <Button Text="End" Clicked="OnHorizontalEnd" />
                <Button Text="Fill" Clicked="OnHorizontalFill" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Панель вертикального выравнивания -->
        <VerticalStackLayout Grid.Row="2" Grid.Column="1"
                              Spacing="10"
                              HorizontalOptions="Center">
            <Label Text="Вертикальное выравнивание"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <HorizontalStackLayout Spacing="10">
                <Button Text="Start" Clicked="OnVerticalStart" />
                <Button Text="Center" Clicked="OnVerticalCenter" />
                <Button Text="End" Clicked="OnVerticalEnd" />
                <Button Text="Fill" Clicked="OnVerticalFill" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Пояснение -->
        <Label Grid.Row="3" Grid.ColumnSpan="2"
               Text="Start — начало, Center — центр, End — конец, Fill — растянуть"
               FontSize="12"
               HorizontalOptions="Center"
               TextColor="Gray" />

    </Grid>

</ContentPage>